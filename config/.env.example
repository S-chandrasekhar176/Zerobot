# ═══════════════════════════════════════════════════════════════
#  ZeroBot G2 — Environment Variables
#  Copy: cp config/.env.example config/.env
#  Then fill in YOUR values. Never commit config/.env to git.
# ═══════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────
# SQLite = true (default, zero config, recommended for single server)
# PostgreSQL = false (set DB_* vars below)
USE_SQLITE=true
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=zerobot
# DB_USER=zerobot_user
# DB_PASSWORD=your_postgres_password

# ── Telegram Bot ───────────────────────────────────────────────
# 1. Open Telegram → @BotFather → /newbot → copy token
# 2. Open @userinfobot → copy your numeric chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Angel One SmartAPI ─────────────────────────────────────────
# Get from: https://smartapi.angelone.in → Create App
# Redirect URL: https://angelone.in
# Primary Static IP: your server's public IP
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=
# TOTP Secret: In your Angel One app → Profile → Enable TOTP
# When QR code appears, use an app like andOTP to extract the base32 secret

# ── Shoonya / Finvasia ─────────────────────────────────────────
# Get API key from: https://shoonya.com → API section
SHOONYA_USER=
SHOONYA_PASSWORD=
SHOONYA_TOTP_SECRET=
SHOONYA_API_KEY=
SHOONYA_VENDOR_CODE=
SHOONYA_IMEI=abc1234

# ── Groq AI (FREE — enhances Gates 6+11) ──────────────────────
# Free: 14,400 requests/day at https://console.groq.com
GROQ_API_KEY=

# ── Dashboard Security ─────────────────────────────────────────
# Set DASHBOARD_PASS to protect the web dashboard with a password.
# Strongly recommended when running on a cloud server.
# Leave blank to disable auth (localhost only).
DASHBOARD_USER=admin
DASHBOARD_PASS=

# ── FinBERT Sentiment (OPTIONAL — heavy: ~500MB, ~2GB RAM) ────
# 0 = disabled (default, uses fast keyword scorer)
# 1 = enabled (better accuracy, install first: pip install transformers torch)
ZEROBOT_USE_FINBERT=0

# ── Testing ────────────────────────────────────────────────────
# Set to 1 to bypass market hours gate (for testing outside trading hours)
# NEVER set this in production
# ZEROBOT_FORCE_MARKET_OPEN=1
