# ═════════════════════════════════════════════════════════════════════════════
# ZeroBot Z1 — Environment Configuration Template
# 
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp config/.env.example config/.env
#   2. Edit config/.env and fill in your credentials
#   3. Set permissions: chmod 600 config/.env  (Linux/Mac)
#   4. IMPORTANT: Never commit config/.env to git (already in .gitignore)
# 
# ═════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# LLM INTEGRATION (Groq) — FREE TIER AVAILABLE
# ──────────────────────────────────────────────────────────────────────────────
# 
# Sign up: https://console.groq.com (14,400 free requests/day)
# 
# Used for:
#   - Trade narrative generation (explain why trades were good/bad)
#   - Session briefing (pre-market AI analysis)
#   - News sentiment scoring (fraud flags, SEBI blocks)
#   - ML confidence override (Gate 6)
#
# Leave empty to disable Groq (bot still works, just without AI features)
GROQ_API_KEY=gsk_your_api_key_here
GROQ_ENABLED=true

# ──────────────────────────────────────────────────────────────────────────────
# REAL-TIME DATA & EXECUTION — SHOONYA (Finvasia)
# ──────────────────────────────────────────────────────────────────────────────
#
# Sign up: https://finvasia.com
# Get credentials: Finvasia web app → Settings → API
#
# Used in:
#   - S-Mode: Real-time WebSocket during market hours
#   - Live (Shoonya): Real-time execution
#   - Dual Mode: Data + execution source
#
# Required for S-Mode and Live trading modes
SHOONYA_LOGIN=your_shoonya_username
SHOONYA_PASSWORD=your_shoonya_password
SHOONYA_TOTP_SECRET=your_2fa_secret_base32  # From AuthenticatorApp
SHOONYA_VENDOR_CODE=finvasia               # Usually "finvasia"
SHOONYA_IMEI=your_imei_code                 # Unique device identifier

# ──────────────────────────────────────────────────────────────────────────────
# DATA FEED & EXECUTION — ANGEL ONE SmartAPI
# ──────────────────────────────────────────────────────────────────────────────
#
# Sign up: https://www.angelone.in
# Get Smart API credentials: Angel One web → Profile → Smart API
#
# Used in:
#   - Hybrid Mode: Angel One data + paper execution
#   - Dual Mode: Angel One data + Shoonya execution
#
# Optional if using Shoonya or Paper modes only
ANGEL_API_KEY=your_smart_api_key
ANGEL_CLIENT_ID=your_client_id
ANGEL_PASSWORD=your_angel_password
ANGEL_TOTP_SECRET=your_2fa_secret_base32  # From Authenticator app

# ──────────────────────────────────────────────────────────────────────────────
# ALERTS & NOTIFICATIONS — TELEGRAM
# ──────────────────────────────────────────────────────────────────────────────
#
# Setup:
#   1. Open Telegram
#   2. Search for @BotFather
#   3. Type /newbot
#   4. Copy the token provided
#   5. Get your chat ID: search @userinfobot, type /start, copy numeric ID
#
# Used for:
#   - Trade entry/exit notifications (with P&L)
#   - Daily performance summaries
#   - Risk alerts (VIX halt, drawdown warnings)
#   - System health checks
#
# Optional — bot works without it, just no Telegram alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_numeric_chat_id

# ──────────────────────────────────────────────────────────────────────────────
# DATABASE — PERSISTENT TRADE LOGGING (Optional)
# ──────────────────────────────────────────────────────────────────────────────
#
# Options:
#   - SQLite (default): Single file, zero config, recommended for development
#   - PostgreSQL: For production and multi-instance deployments
#
# If not set, fallback to JSON file storage (logs/state_backup.json)
USE_SQLITE=true

# PostgreSQL (optional — only needed if not using SQLite)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=zerobot_db
# DB_USER=zerobot_user
# DB_PASSWORD=your_postgres_password

# ──────────────────────────────────────────────────────────────────────────────
# LOGGING & DEBUGGING
# ──────────────────────────────────────────────────────────────────────────────
#
# Log levels: DEBUG (verbose), INFO (default), WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Development mode: More error details, verbose output, slower execution
# Use for debugging issues
DEV_MODE=false

# Verbose logging: Log every tick, every signal (WARNING: 100MB+ logs/day)
VERBOSE_LOGGING=false

# ──────────────────────────────────────────────────────────────────────────────
# TESTING & DEVELOPMENT
# ──────────────────────────────────────────────────────────────────────────────
#
# Force market hours: Useful for testing outside trading hours
ZEROBOT_FORCE_MARKET_OPEN=false

# Use dummy data: When all APIs are unavailable (testing only)
USE_DUMMY_DATA=false

# Dashboard password: Protect web dashboard (http://localhost:8000)
# Leave blank to disable auth (localhost only)
# Set password if deploying on cloud server
DASHBOARD_PASS=

# ──────────────────────────────────────────────────────────────────────────────
# ADVANCED CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────────
#
# Override mode (default: read from config/settings.yaml)
# MODE=paper|s_mode|hybrid|dual|live

# API timeout (seconds) — increase if experiencing rate limits
API_TIMEOUT=10

# Max retries for API calls (broker, data feeds)
MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY NOTES
# ─────────────────────────────────────────────────────────────────────────────
#
# ✓ DO:
#   - Keep config/.env private (git-ignored)
#   - Use strong passwords
#   - Rotate API keys quarterly
#   - Run on a secure VPS (not your personal laptop for live trading)
#
# ✗ DON'T:
#   - Commit .env to version control
#   - Share .env with others
#   - Use same API key across deployments
#   - Store .env in cloud sync (Dropbox, Drive, etc.)
# ─────────────────────────────────────────────────────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASS=

# ── FinBERT Sentiment (OPTIONAL — heavy: ~500MB, ~2GB RAM) ────
# 0 = disabled (default, uses fast keyword scorer)
# 1 = enabled (better accuracy, install first: pip install transformers torch)
ZEROBOT_USE_FINBERT=0

# ── Testing ────────────────────────────────────────────────────
# Set to 1 to bypass market hours gate (for testing outside trading hours)
# NEVER set this in production
# ZEROBOT_FORCE_MARKET_OPEN=1
