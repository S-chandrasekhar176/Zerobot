# ZeroBot — Git Ignore
# NEVER commit credentials or sensitive data

# Environment / credentials
config/.env
config/.env.local
*.key
*.secret

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ML models (large binary files)
models/saved/*.pkl
models/saved/*.joblib
models/saved/*.json

# Database
*.db
*.sqlite
*.sqlite3

# Logs (can be huge)
logs/
*.log

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Data cache
data/cache/
data/storage/

# Linux/cloud specific
*.sh.bak
deploy/*.key
deploy/*.pem

# Virtual environment
venv/
.venv/
env/

# Backup files
*.tar.gz
*.zip
*_backup_*

# Jupyter
*.ipynb
.ipynb_checkpoints/
