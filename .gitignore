# ============================================================================
.vscode/
.idea/
.vs/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
*.sublime-project
*.sublime-workspace
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace
.ropeproject/

