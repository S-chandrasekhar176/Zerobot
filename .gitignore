*.bak
*.tmp
*.temp
*.swp
*.swo
*~
*.orig
*.backup
.*.sw?

# ============================================================================
# DOCKER & CLOUD
# ============================================================================
.dockerignore
.docker/
*.dockerfile
docker-compose.local.yml
deploy/*.key
deploy/*.pem
deploy/*.ppk
.env.docker

# ============================================================================
